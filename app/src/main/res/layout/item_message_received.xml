<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#EAEFF5"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp">

            <!-- Message Text Container -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Memory-Safe Received Media Preview Thumbnail -->
                <ImageView
                    android:id="@+id/ivMessageImage"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_marginBottom="8dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="Received media preview" />

                <TextView
                    android:id="@+id/tvMessageText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="260dp"
                    android:text="Received Message Text"
                    android:textColor="#333333"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvMessageTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="2dp"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    android:text="14:02" />

            </LinearLayout>

            <!-- Tiny Save Icon for Received Attachments -->
            <ImageView
                android:id="@+id/ivSaveAttachment"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:padding="4dp"
                android:scaleType="centerInside"
                android:src="@drawable/save_24px"
                android:visibility="gone"
                android:contentDescription="Save received attachment" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>