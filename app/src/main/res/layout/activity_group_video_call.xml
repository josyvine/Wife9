<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Top Overlay Details -->
    <TextView
        android:id="@+id/tvGroupCallTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="36dp"
        android:text="Mesh Group Call"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvGroupCallState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:text="Broadcasting..."
        android:textColor="#DDDDDD"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvGroupCallTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvGroupCallDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="36dp"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dynamic Video Streams Grid Container -->
    <GridLayout
        android:id="@+id/gridLayoutVideo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:columnCount="2"
        android:rowCount="3"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false"
        app:layout_constraintTop_toBottomOf="@id/tvGroupCallState"
        app:layout_constraintBottom_toTopOf="@id/layoutGroupControl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlaid Control Floating Action Buttons -->
    <LinearLayout
        android:id="@+id/layoutGroupControl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="24dp"
        android:background="#33000000"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabGroupMute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:src="@drawable/mic_24px"
            app:backgroundTint="#AA121212"
            app:tint="#FFFFFF"
            android:contentDescription="Mute Audio Input Stream" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabGroupSwitchCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:src="@drawable/flip_camera_android_24px"
            app:backgroundTint="#AA121212"
            app:tint="#FFFFFF"
            android:contentDescription="Switch Active Camera focus" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabGroupSpeaker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:src="@drawable/volume_up_24px"
            app:backgroundTint="#AA121212"
            app:tint="#FFFFFF"
            android:contentDescription="Toggle Speaker Audio Mixer" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabDeclineGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:src="@drawable/call_end_24px"
            app:backgroundTint="#F44336"
            app:tint="#FFFFFF"
            android:contentDescription="Decline/End Group Call Session" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>